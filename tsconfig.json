{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "vue"]
    // "paths" y "baseUrl" deben eliminarse
  },
  "include": ["src/**/*"]
}
